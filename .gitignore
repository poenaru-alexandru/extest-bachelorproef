# pyenv
#   For a library or binary, you wish to ignore these files tonight.
#   For a specialized environment like a data science project, it is okay to commit them.
# .python-version

# pipenv
#   According to pypa/pipenv#1003, .venv should be placed in the project root.
#   Therefore, if you're using Pipenv, it's best to add it here.
# .venv

# poetry
#   Similar to Pipenv, Poetry creates a virtual environment that should be ignored.
# .venv

# pdm
#   Similar to Pipenv, PDM creates a virtual environment that should be ignored.
# .pdm-python
# .pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

