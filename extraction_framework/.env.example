# Environment variables for Document Extraction Tester

# ============================================
# LLM PROVIDERS CONFIGURATION (JSON Format)
# ============================================
# IMPORTANTE: Il JSON deve essere su una singola riga per compatibilità con .env
# Formato: {"provider_name": {"api_key": "...", "base_url": "...", "models": [...]}}

LLM_PROVIDERS={"nvidia": {"api_key": "nvapi-your-key-here", "base_url": "https://integrate.api.nvidia.com/v1", "models": ["nvidia/llama-3.1-nemotron-70b-instruct", "meta/llama-3.1-70b-instruct", "mistralai/mixtral-8x7b-instruct-v0.1"]}, "local": {"api_key": "not-needed", "base_url": "http://localhost:11434/v1", "models": ["llama3.1", "qwen2.5:14b", "mistral"]}}

# Esempio minimo richiesto (nvidia + local):
# LLM_PROVIDERS={"nvidia": {"api_key": "nvapi-...", "base_url": "https://integrate.api.nvidia.com/v1", "models": ["model1", "model2", "model3"]}, "local": {"base_url": "http://localhost:11434/v1", "models": ["local1", "local2", "local3"]}}

# Note: 
# - Sono supportati solo i provider: nvidia e local
# - api_key è obbligatoria per nvidia
# - api_key per local può essere "not-needed"
# - base_url è consigliata per entrambi i provider
# - models è la lista di modelli disponibili per quel provider
